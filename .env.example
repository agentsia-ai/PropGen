# ============================================================
# PropGen — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Anthropic (required) ---
# Powers request classification, proposal drafting, and the pricing
# assistant.
ANTHROPIC_API_KEY=sk-ant-...

# --- DocuSign (recommended primary e-sign integration) ---
# JWT Grant flow — see docs/API_KEYS.md for the full setup walkthrough.
# Generate a developer account at: https://developers.docusign.com
# DocuSign demo base URL is https://demo.docusign.net/restapi; production
# is https://www.docusign.net/restapi (set in config.yaml, not here).
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=

# Path to the RSA private key file you generated alongside the public
# key uploaded to DocuSign → Apps & Keys. Keep this file out of git
# (the default name `docusign_private.key` is .gitignored).
DOCUSIGN_PRIVATE_KEY_PATH=./docusign_private.key

# Optional inline private key (PEM) — used as a fallback if the path
# above is unset / unreadable. Leave blank if using the file path.
DOCUSIGN_PRIVATE_KEY=

# OAuth host. `account-d.docusign.com` is the demo / developer host;
# `account.docusign.com` is production.
DOCUSIGN_OAUTH_HOST=account-d.docusign.com

# Webhook signing secret. Set this to whatever value you configured on
# DocuSign Connect's HMAC subscription. Leave blank to disable signature
# verification (only safe behind an authenticated edge).
DOCUSIGN_WEBHOOK_SECRET=

# Optional cached access-token file (gitignored). The connector caches
# JWT-grant access tokens here so subsequent calls inside the token's
# TTL skip the round-trip to DocuSign's auth endpoint.
DOCUSIGN_TOKEN_PATH=./.docusign_token.json

# --- Dropbox Sign (optional alternative e-sign provider) ---
# https://app.hellosign.com/home/myAccount#api
DROPBOX_SIGN_API_KEY=

# --- PandaDoc (optional alternative full-stack proposal+e-sign tool) ---
# https://app.pandadoc.com/a/#/settings/api
PANDADOC_API_KEY=

# --- SMTP / Gmail (cover-note email + follow-ups) ---
# Gmail app-password docs: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# --- Twilio (optional SMS follow-ups) ---
# Install with: uv sync --extra sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Inbound webhook receiver ---
# Shared secret used to HMAC-sign incoming requests from website forms /
# embedded proposal-request widgets. Leave blank to disable signature
# verification (only safe behind an authenticated edge).
WEBHOOK_SIGNING_SECRET=

# --- App Settings ---
# Path to the config YAML the engine should load. Defaults to ./config.yaml.
CONFIG_PATH=config.yaml

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
